# Shadow Monarch - English locale

# Preset
shadow-monarch-title = Shadow Monarch
shadow-monarch-preset-description = A Shadow Monarch lurks among the crew...

# Role
roles-antag-shadow-monarch-name = Shadow Monarch
roles-antag-shadow-monarch-description = Extract shadows from corpses, build your army, and ascend to become the Shadow Monarch.

# Briefing
shadow-monarch-briefing = You are the Shadow Monarch. Extract shadows from the dead to build your army. Ascend when you are powerful enough.
shadow-monarch-role-greeting = You feel a dark power dormant within you. You can extract shadows from corpses to create loyal soldiers. Build your army and ascend to your true form. Use the Shadow Extraction abilities on dead bodies to begin.

# Actions - Extraction (3 types)
action-shadow-extract-soldier = Extract Shadow Soldier
action-shadow-extract-soldier-desc = Extract the shadow from a corpse as a balanced shadow soldier (60HP, melee).
action-shadow-extract-tank = Extract Shadow Tank
action-shadow-extract-tank-desc = Extract the shadow from a corpse as a tanky shadow soldier (120HP, slow, melee).
action-shadow-extract-mage = Extract Shadow Mage
action-shadow-extract-mage-desc = Extract the shadow from a corpse as a fragile shadow mage (40HP, ranged attacks).

# Actions - Other abilities
action-shadow-step = Shadow Step
action-shadow-step-desc = Teleport through the shadows to a nearby location.
action-shadow-exchange = Shadow Exchange
action-shadow-exchange-desc = Instantly swap positions with one of your shadow soldiers.
action-shadow-hide = Shadow Hide
action-shadow-hide-desc = Hide a shadow soldier in your shadow. Click on one of your soldiers.
action-shadow-summon = Shadow Summon
action-shadow-summon-desc = Summon all hidden shadow soldiers to your location at once. 30 second cooldown.
action-shadow-domain = Shadow Domain
action-shadow-domain-desc = Create a zone of oppressive darkness around you.
action-shadow-ascend = Ascend
action-shadow-ascend-desc = Ascend to your true form as the Shadow Monarch. Requires 7 extractions.

# Popups
shadow-monarch-target-not-dead = The target must be dead.
shadow-monarch-target-already-shadow = This is already a shadow.
shadow-monarch-army-full = Your shadow army is at maximum capacity.
shadow-monarch-extraction-success = You extract the shadow of {$name}. Rise!
shadow-monarch-awakening = A dark power stirs within you... You have awakened.
shadow-monarch-unlock-step = You have learned Shadow Step. Move through darkness itself.
shadow-monarch-unlock-exchange = You have learned Shadow Exchange. Trade places with your soldiers.
shadow-monarch-unlock-hide-summon = You have learned Shadow Hide and Shadow Summon. Conceal and unleash your soldiers.
shadow-monarch-unlock-domain = You have learned Shadow Domain. Darkness bends to your will.
shadow-monarch-unlock-ascend = You are ready. The power of Ascension awaits.
shadow-monarch-step-used = You step through the shadows.
shadow-monarch-exchange-not-soldier = You can only exchange with your shadow soldiers.
shadow-monarch-exchange-used = You swap positions with your shadow.
shadow-monarch-hide-not-soldier = You can only hide your shadow soldiers.
shadow-monarch-hide-not-yours = That shadow does not serve you.
shadow-monarch-hide-success = You hide the shadow of {$name} within your own shadow.
shadow-monarch-summon-none = You have no hidden shadows to summon.
shadow-monarch-summon-success = You summon {$count} shadows from the darkness!
shadow-monarch-domain-used = Darkness expands around you!
shadow-monarch-ascend-not-ready = You need at least 7 extractions to ascend.
shadow-monarch-ascend-confirm = Are you sure you want to ascend? There is no going back.
shadow-monarch-ascended = You have ascended! The shadows bow to your will!

# Shadow soldier names (type-specific)
shadow-monarch-soldier-name = Shadow Soldier of {$name}
shadow-monarch-tank-name = Shadow Tank of {$name}
shadow-monarch-mage-name = Shadow Mage of {$name}

# Shadow soldier entity names
shadow-monarch-soldier-entity-name = Shadow Soldier
shadow-monarch-soldier-entity-desc = A dark silhouette that moves with unnatural purpose. Its eyes glow with a faint purple light.
shadow-monarch-tank-entity-name = Shadow Tank
shadow-monarch-tank-entity-desc = A hulking dark silhouette, slow but nearly unstoppable. Purple energy crackles across its massive form.
shadow-monarch-mage-entity-name = Shadow Mage
shadow-monarch-mage-entity-desc = A robed dark silhouette that channels shadow bolts. Its hands glow with arcane purple energy.

# Ghost role
shadow-soldier-ghost-role-name = Shadow Soldier
shadow-soldier-ghost-role-tank-name = Shadow Tank
shadow-soldier-ghost-role-mage-name = Shadow Mage
shadow-soldier-ghost-role-description = You are a shadow soldier serving the Shadow Monarch. Destroy their enemies.
shadow-soldier-ghost-role-rules = You are loyal to the Shadow Monarch. Follow their lead and fight their enemies. You can be hidden and summoned by the Monarch.

# Station announcement
shadow-monarch-ascension-announcement = An overwhelming darkness washes over the station. Something ancient has awakened.
shadow-monarch-ascension-sender = Unknown

