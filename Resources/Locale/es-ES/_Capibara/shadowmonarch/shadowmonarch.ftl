# Shadow Monarch - Locale en espanol

# Preset
shadow-monarch-title = Monarca de las Sombras
shadow-monarch-preset-description = Un Monarca de las Sombras acecha entre la tripulacion...

# Role
roles-antag-shadow-monarch-name = Monarca de las Sombras
roles-antag-shadow-monarch-description = Extrae sombras de los cadaveres, construye tu ejercito y asciende para convertirte en el Monarca de las Sombras.

# Briefing
shadow-monarch-briefing = Eres el Monarca de las Sombras. Extrae sombras de los muertos para construir tu ejercito. Asciende cuando seas lo suficientemente poderoso.
shadow-monarch-role-greeting = Sientes un poder oscuro latente dentro de ti. Puedes extraer sombras de los cadaveres para crear soldados leales. Construye tu ejercito y asciende a tu verdadera forma. Usa las habilidades de Extraccion de Sombra en cuerpos muertos para comenzar.

# Actions - Extraction (3 types)
action-shadow-extract-soldier = Extraer Soldado Sombra
action-shadow-extract-soldier-desc = Extrae la sombra de un cadaver como un soldado sombra equilibrado (60HP, cuerpo a cuerpo).
action-shadow-extract-tank = Extraer Tanque Sombra
action-shadow-extract-tank-desc = Extrae la sombra de un cadaver como un soldado sombra resistente (120HP, lento, cuerpo a cuerpo).
action-shadow-extract-mage = Extraer Mago Sombra
action-shadow-extract-mage-desc = Extrae la sombra de un cadaver como un mago sombra fragil (40HP, ataques a distancia).

# Actions - Other abilities
action-shadow-step = Paso de Sombra
action-shadow-step-desc = Teletransportate a traves de las sombras a una ubicacion cercana.
action-shadow-exchange = Intercambio de Sombra
action-shadow-exchange-desc = Intercambia posiciones instantaneamente con uno de tus soldados sombra.
action-shadow-hide = Ocultar Sombra
action-shadow-hide-desc = Oculta un soldado sombra en tu propia sombra. Haz clic en uno de tus soldados.
action-shadow-summon = Invocar Sombras
action-shadow-summon-desc = Invoca todos los soldados sombra ocultos a tu ubicacion de una vez. 30 segundos de enfriamiento.
action-shadow-domain = Dominio de Sombra
action-shadow-domain-desc = Crea una zona de oscuridad opresiva a tu alrededor.
action-shadow-ascend = Ascender
action-shadow-ascend-desc = Asciende a tu verdadera forma como el Monarca de las Sombras. Requiere 7 extracciones.

# Popups
shadow-monarch-target-not-dead = El objetivo debe estar muerto.
shadow-monarch-target-already-shadow = Esto ya es una sombra.
shadow-monarch-army-full = Tu ejercito de sombras esta al maximo de capacidad.
shadow-monarch-extraction-success = Extraes la sombra de {$name}. Levantate!
shadow-monarch-awakening = Un poder oscuro se agita dentro de ti... Has despertado.
shadow-monarch-unlock-step = Has aprendido Paso de Sombra. Muevete a traves de la oscuridad misma.
shadow-monarch-unlock-exchange = Has aprendido Intercambio de Sombra. Intercambia lugares con tus soldados.
shadow-monarch-unlock-hide-summon = Has aprendido Ocultar Sombra e Invocar Sombras. Oculta y desata a tus soldados.
shadow-monarch-unlock-domain = Has aprendido Dominio de Sombra. La oscuridad se doblega ante tu voluntad.
shadow-monarch-unlock-ascend = Estas listo. El poder de la Ascension te espera.
shadow-monarch-step-used = Te mueves a traves de las sombras.
shadow-monarch-exchange-not-soldier = Solo puedes intercambiar con tus soldados sombra.
shadow-monarch-exchange-used = Intercambias posiciones con tu sombra.
shadow-monarch-hide-not-soldier = Solo puedes ocultar a tus soldados sombra.
shadow-monarch-hide-not-yours = Esa sombra no te sirve.
shadow-monarch-hide-success = Ocultas la sombra de {$name} dentro de tu propia sombra.
shadow-monarch-summon-none = No tienes sombras ocultas para invocar.
shadow-monarch-summon-success = Invocas {$count} sombras desde la oscuridad!
shadow-monarch-domain-used = La oscuridad se expande a tu alrededor!
shadow-monarch-ascend-not-ready = Necesitas al menos 7 extracciones para ascender.
shadow-monarch-ascend-confirm = Estas seguro de que quieres ascender? No hay vuelta atras.
shadow-monarch-ascended = Has ascendido! Las sombras se inclinan ante tu voluntad!

# Shadow soldier names (type-specific)
shadow-monarch-soldier-name = Soldado Sombra de {$name}
shadow-monarch-tank-name = Tanque Sombra de {$name}
shadow-monarch-mage-name = Mago Sombra de {$name}

# Shadow soldier entity names
shadow-monarch-soldier-entity-name = Soldado Sombra
shadow-monarch-soldier-entity-desc = Una silueta oscura que se mueve con un proposito antinatural. Sus ojos brillan con una tenue luz purpura.
shadow-monarch-tank-entity-name = Tanque Sombra
shadow-monarch-tank-entity-desc = Una silueta oscura imponente, lenta pero casi imparable. Energia purpura crepita a traves de su forma masiva.
shadow-monarch-mage-entity-name = Mago Sombra
shadow-monarch-mage-entity-desc = Una silueta oscura con tunica que canaliza rayos de sombra. Sus manos brillan con energia purpura arcana.

# Ghost role
shadow-soldier-ghost-role-name = Soldado Sombra
shadow-soldier-ghost-role-tank-name = Tanque Sombra
shadow-soldier-ghost-role-mage-name = Mago Sombra
shadow-soldier-ghost-role-description = Eres un soldado sombra al servicio del Monarca de las Sombras. Destruye a sus enemigos.
shadow-soldier-ghost-role-rules = Eres leal al Monarca de las Sombras. Sigue su liderazgo y lucha contra sus enemigos. Puedes ser ocultado e invocado por el Monarca.

# Station announcement
shadow-monarch-ascension-announcement = Una oscuridad abrumadora invade la estacion. Algo ancestral ha despertado.
shadow-monarch-ascension-sender = Desconocido

