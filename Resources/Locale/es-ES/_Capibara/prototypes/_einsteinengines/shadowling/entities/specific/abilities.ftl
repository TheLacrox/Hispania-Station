ent-ShadowlingAbilitiesPostHatch = habilidades post-eclosión de shadowling
    .desc = Entidad que contiene todas las acciones asignadas después de que un shadowling eclosiona.

ent-ShadowlingAbilitiesObtainable = habilidades obtenibles de shadowling
    .desc = Entidad que contiene todas las acciones que puede obtener un shadowling a través de la conversión de tripulantes.

ent-ShadowlingAbilitiesAscension = habilidades de ascensión de shadowling
    .desc = Entidad que contiene todas las acciones que puede obtener un shadowling a través de la ascensión.

ent-NightmareAbilities = habilidades de ascensión de shadowling
    .desc = Entidad que contiene todos los componentes para las Pesadillas.

ent-LesserShadowlingAbilities = habilidades de shadowling menor
    .desc = Entidad que contiene todos los componentes para los Shadowlings Menores.

ent-ThrallAbilities = habilidades de vasallo
    .desc = Entidad que contiene todos los componentes para los Vasallos tras la Hipnosis.
