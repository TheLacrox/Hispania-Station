ent-PinpointerAnomaly = buscador de anomalías
    .desc = Un rastreador portátil que apunta a cualquier anomalía cuando está apagado. Mantenlo en posición vertical para mayor precisión.

ent-PinpointerArtifact = buscador de artefactos
    .desc = Un rastreador portátil que rastrea todos los artefactos cercanos. Mantenlo en posición vertical para mayor precisión.

ent-PinpointerBorg = buscador de cyborgs
    .desc = Un rastreador portátil que apunta a cualquier silicio cuando está apagado. Mantenlo en posición vertical para mayor precisión.

ent-PinpointerGeneric = buscador genérico
    .desc = Un rastreador portátil que apunta a cualquier objeto cuando está apagado. Mantenlo en posición vertical para mayor precisión.

ent-PinpointerStationGoob = buscador de estaciones
