ent-ArrowEnergy = flecha de energía
    .desc = Una flecha hecha de luz sólida.

ent-ArrowDisabler = flecha deshabilitadora
    .desc = Una flecha hecha de luz sólida. Esta aturde a la víctima de forma no letal.

ent-ArrowFiery = flecha ardiente
    .desc = Una flecha hecha de luz sólida. Esta quema a la víctima.

ent-ArrowFreeze = flecha congeladora
    .desc = Una flecha hecha de luz sólida. Esta congela a la víctima.

ent-ArrowExplosive = flecha explosiva
    .desc = Una flecha hecha de luz sólida. Esta explota al impactar, pero la energía se disipa rápidamente, no vuela muy lejos.

ent-ArrowXray = flecha de rayos X
    .desc = Una flecha hecha de luz sólida. Esta atraviesa todo.

ent-ArrowBee = flecha de abejas
    .desc = Una flecha hecha de luz sólida. Esta invoca abejas enfurecidas.

ent-ArrowIon = flecha iónica
    .desc = Una flecha hecha de luz sólida. Causa un EMP al impactar.
