ent-WeaponMechCombatPulseRifle = eZ-14 mk2 Rifle de pulso pesado
    .desc = Dispara un láser de pulso pesado.

ent-WeaponMechCombatImmolationGun = ZFI Cañón de inmolación
    .desc = Un cañón para mechs de batalla que dispara rayos de alta temperatura.

ent-WeaponMechCombatSolarisLaser = CH-LC Cañón láser "Solaris"
    .desc = Un rayo láser de combate experimental montado que dispara mucho más rápido que el "Firedart" pero a un costo mucho mayor.

ent-WeaponMechCombatFiredartLaser = CH-PS Láser "Firedart"
    .desc = El armamento de combate estándar de los mechs es un láser de combate montado.

ent-WeaponMechCombatTeslaCannon = P-X Cañón Tesla
    .desc = Un arma para mechs de combate que dispara bolas de energía, basada en el principio de un motor Tesla experimental.

ent-WeaponMechCombatDisabler = CH-PD Deshabilitador
    .desc = Una pistola paralizante no letal montada que te permite inmovilizar intrusos.

ent-WeaponMechCombatTaser = PBT Táser montado "Pacificador"
    .desc = Un táser no letal montado que te permite aturdir intrusos.

ent-WeaponMechCombatShotgun = LBX AC 10 "Dispersión"
    .desc = Una escopeta montada para uso contra infantería enemiga.

ent-WeaponMechCombatShotgunIncendiary = FNX-99 Carabina "Hades"
    .desc = Una escopeta montada con munición incendiaria.

ent-WeaponMechCombatUltraRifle = Ultra AC-2
    .desc = Un rifle montado para uso contra infantería enemiga.

ent-WeaponMechCombatMissileRack8 = SRM-8 Lanzadera de misiles ligera
    .desc = Lanza misiles de brecha de baja explosión diseñados para explotar solo al impactar contra un objetivo resistente.

ent-WeaponMechCombatMissileRack6 = BRM-6 Lanzadera de misiles
    .desc = Los tubos deben recargarse desde el exterior.

ent-WeaponMechCombatFlashbangLauncher = SGL-6 Lanzador de granadas cegadoras
    .desc = Un lanzador montado que dispara granadas de destello para lidiar con disturbios.
