ent-BaseAutomationFilter = filtro
    .desc = Un filtro que se puede instalar en máquinas de fábrica.

ent-AutomationFilterLabel = filtro de etiqueta
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este escanea las etiquetas de los objetos adjuntos.

ent-AutomationFilterName = filtro de nombre
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este usa tecnología de visión de IA compleja para identificar objetos.

ent-AutomationFilterStack = filtro de pila
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este pesa los objetos para compararlo con el tamaño de una pila.

ent-AutomationFilterPressure = filtro de presión
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este tiene un barómetro para comprobar la presión de los gases.

ent-AutomationFilterCombined = filtro combinado
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este usa una puerta lógica para combinar 2 filtros de objetos instalados.

ent-AutomationFilterAnchor = filtro de anclaje
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este detecta un objeto anclonable, y si está anclado o no.

ent-AutomationFilterMob = filtro de mobs
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este detecta criaturas vivas y filtra según los estados vivo, crítico o muerto.

ent-AutomationFilterCuff = filtro de esposas
    .desc = Un filtro que se puede instalar en máquinas de fábrica. Este detecta si las personas están esposadas... ¿quién hizo esto!?
