ent-ShuttleGunBase = cañón de lanzadera

ent-ShuttleGunSvalinnMachineGun = LSE-400c "Svalinn machine gun"
    .desc = Unidad láser estacionaria básica. Efectiva contra objetivos vivos y electrónica. Usa células de energía normales para disparar, y tiene una cadencia de disparo extremadamente alta.

ent-ShuttleGunPerforator = LSE-1200c "Perforator"
    .desc = Unidad láser estacionaria avanzada. ¡Aniquila la electrónica y es extremadamente peligrosa para la salud! Usa la jaula de energía para disparar.

ent-ShuttleGunFriendship = EXP-320g "Friendship"
    .desc = Un pequeño lanzagranadas estacionario que contiene 2 granadas.

ent-ShuttleGunDuster = EXP-2100g "Duster"
    .desc = Un potente lanzagranadas estacionario. Se requiere un cartucho para su uso.

ent-ShuttleGunPirateCannon = cañón de barco pirata
    .desc = ¡Kaboom!

ent-ShuttleGunKinetic = PTK-800 "Matter Dematerializer"
    .desc = Torreta minera estacionaria de salvamento. Acumula cargas gradualmente por sí misma, extremadamente efectiva para la excavación de asteroides.
