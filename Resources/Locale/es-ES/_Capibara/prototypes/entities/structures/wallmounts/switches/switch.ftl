ent-SignalSwitch = interruptor de señal
    .desc = Es un interruptor para alternar la energía de las cosas.

ent-SignalButton = botón de señal
    .desc = Es un botón para activar algo.

ent-ApcNetSwitch = interruptor de red APC
    .desc = Es un interruptor para alternar las luces conectadas al mismo APC.

ent-SignalSwitchDirectional = interruptor de señal

ent-SignalButtonDirectional = botón de señal

ent-ApcNetSwitchDirectional = interruptor de red APC

ent-LockableButton = botón con cerradura

ent-ButtonFrame = marco de botón
    .desc = Es un marco para ayudar a distinguir visualmente los interruptores.
