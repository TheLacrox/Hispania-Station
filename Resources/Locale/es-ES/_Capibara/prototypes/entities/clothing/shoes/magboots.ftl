ent-ClothingShoesBootsMagBase = magboots
    .desc = Botas magnéticas, a menudo usadas durante la actividad extravehicular para asegurarse de que el usuario permanezca sujeto al vehículo de forma segura.

ent-ClothingShoesBootsMagAdv = magboots avanzadas
    .desc = Botas magnéticas de última generación que no ralentizan al portador.

ent-ClothingShoesBootsMagBlinding = magboots de velocidad cegadora
    .desc = Quedarían de maravilla en alguien que va a buscarlas como tú.

ent-ClothingShoesBootsMagSyndie = magboots rojo sangre
    .desc = Botas magnéticas de ingeniería inversa con una fuerte tracción magnética y propulsores integrados. Puede contener 0,75 L de gas.

ent-ActionToggleMagboots = Activar magboots
    .desc = Activa y desactiva las magboots.
