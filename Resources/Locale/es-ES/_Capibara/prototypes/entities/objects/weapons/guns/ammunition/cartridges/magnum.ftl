ent-BaseCartridgeMagnum = cartucho (.45 magnum)

ent-CartridgeMagnum = cartucho (.45 magnum)
    .desc = Cartucho magnum pesado usado principalmente por revólveres. La munición cinética estándar es común y útil en la mayoría de situaciones.

ent-CartridgeMagnumPractice = cartucho (.45 magnum de práctica)
    .desc = Cartucho magnum pesado usado principalmente por revólveres. La munición de tiza es generalmente inofensiva, usada para practicar.

ent-CartridgeMagnumIncendiary = cartucho (.45 magnum incendiario)
    .desc = Cartucho magnum pesado usado principalmente por revólveres. La munición incendiaria contiene un compuesto auto-ignitable que prende fuego al objetivo.

ent-CartridgeMagnumAP = cartucho (.45 magnum perforante)
    .desc = Cartucho magnum pesado usado principalmente por revólveres. La munición perforante es reconocida por su capacidad de atravesar directamente el chaleco antibalas.

ent-CartridgeMagnumUranium = cartucho (.45 magnum de uranio)
    .desc = Cartucho magnum pesado usado principalmente por revólveres. La munición de uranio reemplaza el núcleo de plomo de la bala con material fisionable, irradiando al objetivo desde adentro.
