ent-ActionRatKingOrderStay = Quedarse
    .desc = Ordena a tu ejército que se quede en su lugar.

ent-ActionRatKingOrderFollow = Seguir
    .desc = Ordena a tu ejército que te siga.

ent-ActionRatKingOrderCheeseEm = A por ellos
    .desc = Ordena a tu ejército que ataque a quien señales.

ent-ActionRatKingOrderLoose = Libre
    .desc = Ordena a tu ejército que actúe a su voluntad.
