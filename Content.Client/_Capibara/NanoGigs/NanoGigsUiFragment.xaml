<nanogigs:NanoGigsUiFragment xmlns:nanogigs="clr-namespace:Content.Client._Capibara.NanoGigs"
                             xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                             xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                             xmlns="https://spacestation14.io" Margin="1 0 2 0">

    <PanelContainer StyleClasses="BackgroundDark" />
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">

        <!-- Header bar -->
        <controls:StripeBack MinSize="0 36" VerticalExpand="False">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="8 0">
                <Label Text="{Loc 'nanogigs-program-name'}" StyleClasses="LabelHeading"
                       VerticalAlignment="Center" HorizontalExpand="True" />
                <Label Name="BalanceLabel" StyleClasses="LabelSubText"
                       VerticalAlignment="Center" Margin="0 0 4 0" />
                <Button Name="AlertsButton" ToggleMode="True" Margin="0 0 2 0">
                    <Label Name="AlertsLabel" VerticalAlignment="Center" HorizontalAlignment="Center"
                           StyleClasses="LabelSubText" />
                </Button>
            </BoxContainer>
        </controls:StripeBack>

        <!-- Error message -->
        <PanelContainer Name="ErrorPanel" Visible="False" Margin="4 2">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#20cc3333" ContentMarginLeftOverride="6"
                                  ContentMarginRightOverride="6" ContentMarginTopOverride="3"
                                  ContentMarginBottomOverride="3" />
            </PanelContainer.PanelOverride>
            <Label Name="ErrorLabel" StyleClasses="LabelSubText" />
        </PanelContainer>

        <!-- Tab container -->
        <TabContainer Name="Tabs" HorizontalExpand="True" VerticalExpand="True">

            <!-- Tab 1: Job Board (or Active Job view) -->
            <BoxContainer Name="JobBoardTab" Orientation="Vertical" HorizontalExpand="True"
                          VerticalExpand="True">

                <!-- Normal browse view -->
                <BoxContainer Name="BrowseView" Orientation="Vertical" HorizontalExpand="True"
                              VerticalExpand="True">
                    <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="JobListContainer" Orientation="Vertical" HorizontalExpand="True"
                                      Margin="4" SeparationOverride="2" />
                    </ScrollContainer>
                    <!-- Empty state -->
                    <Label Name="EmptyBoardLabel" Text="{Loc 'nanogigs-ui-empty-board'}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           StyleClasses="LabelSubText" Visible="False" />
                </BoxContainer>

                <!-- Active job view (when taker has accepted a job) -->
                <BoxContainer Name="ActiveJobView" Orientation="Vertical" HorizontalExpand="True"
                              VerticalExpand="True" Visible="False" Margin="4">
                    <controls:StripeBack MinSize="0 32" VerticalExpand="False" Margin="0 0 0 4">
                        <Label Text="{Loc 'nanogigs-ui-active-job-header'}" StyleClasses="LabelHeading"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </controls:StripeBack>

                    <PanelContainer HorizontalExpand="True" VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#1a1a2e" ContentMarginLeftOverride="10"
                                              ContentMarginRightOverride="10" ContentMarginTopOverride="8"
                                              ContentMarginBottomOverride="8" BorderColor="#333355"
                                              BorderThickness="1" />
                        </PanelContainer.PanelOverride>

                        <BoxContainer Orientation="Vertical" HorizontalExpand="True">
                            <RichTextLabel Name="ActiveJobTitle" Margin="0 0 0 4" HorizontalExpand="True" />

                            <PanelContainer StyleClasses="LowDivider" Margin="0 4" />

                            <RichTextLabel Name="ActiveJobDescription" HorizontalExpand="True" Margin="0 4 0 0" />
                            <RichTextLabel Name="ActiveJobLocation" HorizontalExpand="True" Margin="0 4 0 0" />
                            <RichTextLabel Name="ActiveJobPoster" HorizontalExpand="True" Margin="0 2 0 0" />

                            <PanelContainer StyleClasses="LowDivider" Margin="0 6" />

                            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                                <Label Text="{Loc 'nanogigs-ui-reward'}" StyleClasses="LabelSubText"
                                       VerticalAlignment="Center" />
                                <Label Name="ActiveJobPay" StyleClasses="LabelHeading"
                                       VerticalAlignment="Center" Margin="4 0 0 0" />
                            </BoxContainer>

                            <Control VerticalExpand="True" />

                            <Button Name="AbandonButton" Text="{Loc 'nanogigs-ui-abandon'}"
                                    HorizontalAlignment="Right" Margin="0 8 0 0" />
                        </BoxContainer>
                    </PanelContainer>
                </BoxContainer>

            </BoxContainer>

            <!-- Tab 2: My Jobs -->
            <BoxContainer Name="MyJobsTab" Orientation="Vertical" HorizontalExpand="True"
                          VerticalExpand="True">
                <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="MyJobsContainer" Orientation="Vertical" HorizontalExpand="True"
                                  Margin="4" SeparationOverride="2" />
                </ScrollContainer>
                <Label Name="EmptyMyJobsLabel" Text="{Loc 'nanogigs-ui-empty-myjobs'}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       StyleClasses="LabelSubText" Visible="False" />
            </BoxContainer>

            <!-- Tab 3: Post Job -->
            <BoxContainer Name="PostJobTab" Orientation="Vertical" HorizontalExpand="True"
                          VerticalExpand="True" Margin="6">

                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2 0 2">
                    <Label Text="{Loc 'nanogigs-ui-post-title-label'}" StyleClasses="LabelSubText"
                           HorizontalExpand="True" />
                    <Label Name="TitleCounter" StyleClasses="LabelSubText" />
                </BoxContainer>
                <LineEdit Name="TitleInput" HorizontalExpand="True"
                          PlaceHolder="{Loc 'nanogigs-ui-post-title-placeholder'}" />

                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 6 0 2">
                    <Label Text="{Loc 'nanogigs-ui-post-description-label'}" StyleClasses="LabelSubText"
                           HorizontalExpand="True" />
                    <Label Name="DescriptionCounter" StyleClasses="LabelSubText" />
                </BoxContainer>
                <LineEdit Name="DescriptionInput" HorizontalExpand="True"
                          PlaceHolder="{Loc 'nanogigs-ui-post-description-placeholder'}" />

                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 6 0 2">
                    <Label Text="{Loc 'nanogigs-ui-post-location-label'}" StyleClasses="LabelSubText"
                           HorizontalExpand="True" />
                    <Label Name="LocationCounter" StyleClasses="LabelSubText" />
                </BoxContainer>
                <LineEdit Name="LocationInput" HorizontalExpand="True"
                          PlaceHolder="{Loc 'nanogigs-ui-post-location-placeholder'}" />

                <Label Text="{Loc 'nanogigs-ui-post-pay-label'}" StyleClasses="LabelSubText"
                       Margin="0 6 0 2" />
                <SpinBox Name="PayInput" HorizontalExpand="True" />

                <PanelContainer Margin="0 6 0 0">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#252525d9" ContentMarginLeftOverride="6"
                                          ContentMarginRightOverride="6" ContentMarginTopOverride="4"
                                          ContentMarginBottomOverride="4" />
                    </PanelContainer.PanelOverride>
                    <Label Text="{Loc 'nanogigs-ui-escrow-note'}" StyleClasses="LabelSubText" />
                </PanelContainer>

                <Control VerticalExpand="True" />

                <Button Name="PostButton" Text="{Loc 'nanogigs-ui-post-button'}"
                        HorizontalExpand="True" Margin="0 4 0 0" />
            </BoxContainer>

        </TabContainer>
    </BoxContainer>
</nanogigs:NanoGigsUiFragment>
